# Vantage / OKF pipeline environment — TEMPLATE.
#
# Copy this file to `.env` (which is gitignored) and paste the REAL, freshly
# rotated values. Nothing in this file is a real credential — every value is a
# placeholder. The pipeline scripts and backend read these via os.environ /
# systemd EnvironmentFile; no key should ever be hardcoded in source again.
#
#   cp .env.example .env      # then edit .env with real secrets
#   sudo install -m 0640 -o root -g ares .env /opt/ares/Vantage/.env
#
# systemd loads it via `EnvironmentFile=/opt/ares/Vantage/.env`
# (see pipeline/vantage.service.example). To run a script by hand:
#   set -a && . ./.env && set +a && python pipeline/<script>.py

# ── Vantage API ───────────────────────────────────────────────
VANTAGE_URL=http://localhost:8001
# Agent key used by pipeline daemons, telegram webhook, strix scan, etc.
VANTAGE_KEY=REPLACE_WITH_ROTATED_VANTAGE_AGENT_KEY
# Admin key — used by the service/systemd layer only, never by pipeline code.
VANTAGE_ADMIN_KEY=REPLACE_WITH_ROTATED_VANTAGE_ADMIN_KEY

# ── Solana data / RPC ─────────────────────────────────────────
# Helius RPC + Enhanced Transactions API (balances, wallet trade history).
HELIUS_API_KEY=REPLACE_WITH_ROTATED_HELIUS_KEY
# Birdeye market-data API.
BIRDEYE_KEY=REPLACE_WITH_ROTATED_BIRDEYE_KEY

# ── Gitea (code overview / pipeline push) ─────────────────────
GITEA_URL=http://localhost:3001
GITEA_TOKEN=REPLACE_WITH_ROTATED_GITEA_TOKEN

# ── LLM gateway (Strix / OmniRoute) ───────────────────────────
STRIX_LLM=deepseek/deepseek-chat
LLM_API_KEY=REPLACE_WITH_ROTATED_LLM_KEY

# ── Test fixtures (backend/routers/genesis_test.py) ───────────
TEST_KEY=REPLACE_WITH_A_TEST_AGENT_KEY
TEST_KEY_2=REPLACE_WITH_A_SECOND_TEST_AGENT_KEY

# ── Trading ───────────────────────────────────────────────────
# Public wallet address is fine here. The PRIVATE KEY / soul-seed must NEVER be
# committed or placed in this file — keep it in a 0600 file outside any repo.
TRADE_WALLET=85SFCuohae8gNQZXcYXm41vyeabc2YpAmietS6CbySYx
# sol-cli wallet name used by the live orchestrator.
WALLET=ogun
DB_PATH=/opt/ares/Vantage/data/vantage.db
# 0 = paper (safe default), 1 = execute real trades. Leave 0 unless intentional.
LIVE_MODE=0
# Poll interval (seconds) for the wallet trade/balance trackers.
WALLET_POLL_SECONDS=60
